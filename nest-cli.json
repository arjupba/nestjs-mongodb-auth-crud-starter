{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "auth-guards": {
      "type": "library",
      "root": "libs/auth-guards",
      "entryFile": "index",
      "sourceRoot": "libs/auth-guards/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth-guards/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "http-client": {
      "type": "library",
      "root": "libs/http-client",
      "entryFile": "index",
      "sourceRoot": "libs/http-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/http-client/tsconfig.lib.json"
      }
    },
    "logger": {
      "type": "library",
      "root": "libs/logger",
      "entryFile": "index",
      "sourceRoot": "libs/logger/src",
      "compilerOptions": {
        "tsConfigPath": "libs/logger/tsconfig.lib.json"
      }
    }
  }
}